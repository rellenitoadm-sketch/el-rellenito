# ─────────────────────────────────────────────────────────────
#  Variables de entorno — El Rellenito
#  Copia este archivo a `.env.local` y rellena los valores reales.
#  En producción (Vercel): cárgalas en Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────────
# Panel: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica
# service_role key — SECRETA (server-only, nunca en el navegador ni en git):
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# ── NEGOCIO ───────────────────────────────────────────────────
# Número de WhatsApp para recibir pedidos (formato internacional sin +):
NEXT_PUBLIC_WHATSAPP_NUMBER=584247207067

# ── ACCESO AL PANEL OCULTO (server-only, NO usar NEXT_PUBLIC_) ─
# ADMIN_PIN → acceso total (pedidos, productos, métricas, CRM)
# STAFF_PIN → trabajadores (pedidos + productos)
# ⚠️ Cambia estos valores antes de producción.
ADMIN_PIN=000000
STAFF_PIN=000000

# ── NOTIFICACIONES PUSH (Web Push / VAPID) ────────────────────
# Genera el par con:  npx web-push generate-vapid-keys
# La PUBLIC va al navegador (NEXT_PUBLIC_); la PRIVATE es server-only.
# SUBJECT debe ser un email del negocio (no personal).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu_vapid_public_key
VAPID_PRIVATE_KEY=tu_vapid_private_key
VAPID_SUBJECT=mailto:admin@elrellenito.com

# ── OPCIONAL ──────────────────────────────────────────────────
# Protege el endpoint del cron de tasas (/api/cron/refresh-rate).
# Si lo defines, Vercel Cron debe enviar "Authorization: Bearer <CRON_SECRET>".
# CRON_SECRET=una_cadena_larga_aleatoria

# ── AUTOMATIZACIONES (n8n / Make / Zapier) ────────────────────
# Si defines la URL, cada pedido nuevo y cada cambio de estado se envía como
# POST JSON a ese webhook → desde ahí disparas WhatsApp ("en camino", etc.).
# N8N_WEBHOOK_URL=https://tu-n8n.com/webhook/rellenito-pedidos
# N8N_WEBHOOK_SECRET=cadena_secreta_para_validar_origen
